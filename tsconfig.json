{
  "compilerOptions": {
    "target": "ES2022",                     
    "module": "node16",                          
    "moduleResolution": "node16",
    "types": ["node"],                          
    "esModuleInterop": true,                    
    "forceConsistentCasingInFileNames": true,    
    "strict": true,                             
    "skipLibCheck": true                        
  },
  "include": ["src/**/*"]                       
}